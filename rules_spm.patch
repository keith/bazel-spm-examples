    Remove .swift-version files before running spm
    
    Swiftly always respects .swift-version files, which can lead to spm
    commands failing if the repo's requested version isn't installed.
    Ideally there would be an env var / flag to stop this upstream:
    https://github.com/swiftlang/swiftly/issues/504

diff --git a/swiftpkg/internal/repository_utils.bzl b/swiftpkg/internal/repository_utils.bzl
index 9501466b..888e1271 100644
--- a/swiftpkg/internal/repository_utils.bzl
+++ b/swiftpkg/internal/repository_utils.bzl
@@ -52,6 +52,13 @@ def _execute_spm_command(
     env_overrides = {"SDKROOT": ""}
     exec_env = dicts.add(env, env_overrides)
 
+    # A `.swift-version` file in the package root can hijack Swift toolchain
+    # proxies (e.g. `swiftly`) into requiring a version that isn't installed.
+    repository_ctx.execute(
+        ["rm", "-f", ".swift-version"],
+        working_directory = working_directory,
+    )
+
     exec_result = repository_ctx.execute(
         exec_args,
         environment = exec_env,
