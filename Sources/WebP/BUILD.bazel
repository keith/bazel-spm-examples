load("@rules_swift//swift:swift.bzl", "swift_binary")
load("//:apple_build_tests.bzl", "apple_build_tests")

swift_binary(
    name = "webp_example",
    srcs = ["WebPExample.swift"],
    tags = ["manual"],
    target_compatible_with = ["@platforms//os:ios"],
    deps = [
        "@WebP",
    ],
)

apple_build_tests(
    exclude = [
        "macos",
        "tvos",
        "watchos",
        "visionos",
    ],
    targets = [":webp_example"],
)
